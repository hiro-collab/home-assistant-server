# Copy this file to .env if your process manager loads dotenv files.
# Uvicorn/FastAPI itself does not read .env automatically.

# Path to the YAML config. Defaults to config/home-control.yaml.
HOME_CONTROL_CONFIG=config/home-control.yaml

# Token Dify/AITuberKit/sword-voice-agent must send to this bridge.
# Generate a real value with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Send it as either:
#   Authorization: Bearer <token>
# or:
#   X-API-Token: <token>
HOME_CONTROL_API_TOKEN=REPLACE_WITH_RANDOM_BRIDGE_TOKEN

# Long-lived access token created in Home Assistant.
HOME_ASSISTANT_TOKEN=REPLACE_WITH_HOME_ASSISTANT_LONG_LIVED_TOKEN

# Optional E2E test mode for configured fault injection rules. Default is off.
# Set to 1 only in local verification environments.
HOME_CONTROL_FAULT_MODE=0
